PORT=8787

# Default: real Groth16; mock = proof 0x01 + 9 public inputs (only if your on-chain verifier matches)
ZK_PROVER_IMPLEMENTATION=snarkjs

# Optional: Authorization: Bearer <token> (must match Medoxie ZK_PROVER_AUTH_TOKEN)
ZK_PROVER_AUTH_TOKEN=

# Optional overrides (defaults: circuits/exam_pass.wasm and circuits/exam_pass_final.zkey next to published src/)
# ZK_WASM_PATH=
# ZK_ZKEY_PATH=

ZK_SNARKJS_TIMEOUT_MS=120000
