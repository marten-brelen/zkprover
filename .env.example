PORT=8787

# Default: real Groth16 (set ZK_WASM_PATH + ZK_ZKEY_PATH)
# mock = proof 0x01 + 9 public inputs (only if your on-chain verifier matches)
ZK_PROVER_IMPLEMENTATION=snarkjs

# Optional: Authorization: Bearer <token> (must match Medoxie ZK_PROVER_AUTH_TOKEN)
ZK_PROVER_AUTH_TOKEN=

# Proving keys are not in git; paths must exist at runtime (see README Railway checklist).
# Baked into image under /app/circuits (CI copies artifacts before docker build):
ZK_WASM_PATH=/app/circuits/exam_pass.wasm
ZK_ZKEY_PATH=/app/circuits/exam_pass_final.zkey
# Or persistent Railway volume mounted at /data/circuits:
# ZK_WASM_PATH=/data/circuits/exam_pass.wasm
# ZK_ZKEY_PATH=/data/circuits/exam_pass_final.zkey

ZK_SNARKJS_TIMEOUT_MS=120000
